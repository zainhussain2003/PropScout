# PropScout environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Walk Score
WALKSCORE_API_KEY=your_walkscore_key_here

# Mapbox
MAPBOX_TOKEN=your_mapbox_token_here

# Google Places
GOOGLE_PLACES_KEY=your_google_places_key_here

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key_here

# Scraper proxy rotation (optional — leave blank to scrape without proxies)
# Use residential proxy URLs: http://user:pass@host:port
PROXY_1=
PROXY_2=
PROXY_3=

# Rate limiter state file path (optional — defaults to /tmp/propscout_rate_state.json)
RATE_LIMITER_STATE=/tmp/propscout_rate_state.json

# Internal service URLs (set after Railway deploy)
CALC_ENGINE_URL=http://localhost:8000
SCRAPER_SERVICE_URL=http://localhost:3002
API_URL=http://localhost:3001
