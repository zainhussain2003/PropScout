# PropScout environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_PRICE_PRO=price_your_investor_pro_price_id_here
STRIPE_PRICE_PROFESSIONAL=price_your_professional_price_id_here
STRIPE_PRICE_TEAM=price_your_team_price_id_here

# Frontend Supabase (exposed to browser — anon key only)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_API_URL=http://localhost:3001

# Walk Score
WALKSCORE_API_KEY=your_walkscore_key_here

# Mapbox
MAPBOX_TOKEN=your_mapbox_token_here
# Frontend map rendering (exposed to browser — must be a PUBLIC pk.* token,
# never a secret sk.* key). Without it the report shows the SVG placeholder map.
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Google Places
GOOGLE_PLACES_KEY=your_google_places_key_here

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key_here

# Internal service URLs (set after Railway deploy)
CALC_ENGINE_URL=http://localhost:8000
API_URL=http://localhost:3001
SCRAPER_URL=http://localhost:8001
FRONTEND_URL=http://localhost:5173
